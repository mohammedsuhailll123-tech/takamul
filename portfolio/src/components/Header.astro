---
// Header.astro
---

<header class="sticky top-0 z-50 w-full bg-canvas/80 backdrop-blur-md border-b border-hairline h-16 flex items-center transition-all duration-300">
  <div class="max-w-[1400px] w-full mx-auto px-4 md:px-6 flex items-center justify-between">
    
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group" id="nav-logo">
      <span class="font-mono font-bold text-primary text-sm tracking-tight transition-transform group-hover:scale-110 flex items-center justify-center bg-canvas-soft border border-hairline px-2 py-0.5 rounded-sm shadow-sm">
        &lt;/&gt;
      </span>
      <span class="font-sans font-bold text-sm tracking-tight text-ink">
        suhailll.dev
      </span>
    </a>

    <!-- Navigation links (Desktop) -->
    <nav class="hidden md:flex items-center gap-1">
      <a href="#projects" class="text-body hover:text-ink text-sm font-medium rounded-full px-3 py-1.5 transition-colors hover:bg-canvas-soft-2/60">
        Projects
      </a>
      <a href="#experience" class="text-body hover:text-ink text-sm font-medium rounded-full px-3 py-1.5 transition-colors hover:bg-canvas-soft-2/60">
        Experience
      </a>
      <a href="#skills" class="text-body hover:text-ink text-sm font-medium rounded-full px-3 py-1.5 transition-colors hover:bg-canvas-soft-2/60">
        Skills
      </a>
      <a href="#contact" class="text-body hover:text-ink text-sm font-medium rounded-full px-3 py-1.5 transition-colors hover:bg-canvas-soft-2/60">
        Contact
      </a>
    </nav>

    <!-- CTAs (Desktop) -->
    <div class="hidden md:flex items-center gap-2">
      <a 
        href="https://github.com" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="flex items-center justify-center border border-hairline hover:border-hairline-strong text-ink bg-canvas font-sans font-medium text-xs rounded-sm px-3 h-7 transition-colors"
      >
        GitHub
      </a>
      <a 
        href="#contact" 
        class="flex items-center justify-center bg-primary text-on-primary hover:bg-primary/90 font-sans font-semibold text-xs rounded-sm px-3.5 h-7 transition-all hover:shadow-sm"
      >
        Hire Me
      </a>
    </div>

    <!-- Hamburger Menu Toggle (Mobile) -->
    <button 
      id="mobile-menu-toggle" 
      class="flex md:hidden flex-col gap-1.5 p-2 rounded-sm hover:bg-canvas-soft-2 transition-colors cursor-pointer"
      aria-label="Toggle menu"
    >
      <span class="w-5 h-0.5 bg-ink transition-transform duration-300 origin-center" id="hamburger-top"></span>
      <span class="w-5 h-0.5 bg-ink transition-opacity duration-300" id="hamburger-mid"></span>
      <span class="w-5 h-0.5 bg-ink transition-transform duration-300 origin-center" id="hamburger-bot"></span>
    </button>
  </div>

  <!-- Mobile Overlay Menu -->
  <div 
    id="mobile-menu-overlay" 
    class="fixed inset-0 top-16 z-40 bg-canvas w-full h-[calc(100vh-64px)] hidden flex-col px-6 py-8 border-t border-hairline animate-fade-in"
  >
    <nav class="flex flex-col gap-4 text-center mt-8">
      <a href="#projects" class="mobile-nav-link text-body hover:text-ink font-semibold text-xl tracking-tight py-2 border-b border-canvas-soft-2">
        Projects
      </a>
      <a href="#experience" class="mobile-nav-link text-body hover:text-ink font-semibold text-xl tracking-tight py-2 border-b border-canvas-soft-2">
        Experience
      </a>
      <a href="#skills" class="mobile-nav-link text-body hover:text-ink font-semibold text-xl tracking-tight py-2 border-b border-canvas-soft-2">
        Skills
      </a>
      <a href="#contact" class="mobile-nav-link text-body hover:text-ink font-semibold text-xl tracking-tight py-2 border-b border-canvas-soft-2">
        Contact
      </a>
      
      <div class="flex flex-col gap-3 mt-12 px-4">
        <a 
          href="https://github.com" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="flex items-center justify-center border border-hairline text-ink bg-canvas font-sans font-medium text-sm rounded-sm py-3 transition-colors"
        >
          GitHub
        </a>
        <a 
          href="#contact" 
          class="flex items-center justify-center bg-primary text-on-primary font-sans font-semibold text-sm rounded-sm py-3 transition-colors"
        >
          Hire Me
        </a>
      </div>
    </nav>
  </div>
</header>

<style>
  /* Custom small animation for mobile menu fade-in */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>

<script>
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const overlay = document.getElementById('mobile-menu-overlay');
  const topBar = document.getElementById('hamburger-top');
  const midBar = document.getElementById('hamburger-mid');
  const botBar = document.getElementById('hamburger-bot');
  const navLinks = document.querySelectorAll('.mobile-nav-link');

  let isOpen = false;

  function toggleMenu() {
    isOpen = !isOpen;
    if (isOpen) {
      overlay?.classList.remove('hidden');
      overlay?.classList.add('flex');
      document.body.style.overflow = 'hidden';
      
      // Transform hamburger into an 'X'
      if (topBar && midBar && botBar) {
        topBar.style.transform = 'translateY(6px) rotate(45deg)';
        midBar.style.opacity = '0';
        botBar.style.transform = 'translateY(-6px) rotate(-45deg)';
      }
    } else {
      overlay?.classList.remove('flex');
      overlay?.classList.add('hidden');
      document.body.style.overflow = '';
      
      // Transform 'X' back to hamburger
      if (topBar && midBar && botBar) {
        topBar.style.transform = '';
        midBar.style.opacity = '1';
        botBar.style.transform = '';
      }
    }
  }

  toggleBtn?.addEventListener('click', toggleMenu);

  // Close menu when link is clicked
  navLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (isOpen) toggleMenu();
    });
  });
</script>
