---

<section id="certifications" class="py-24 bg-canvas border-b border-hairline relative">
  
  <!-- Ambient slow-shift gradient for backdrop details -->
  <div class="absolute inset-0 pointer-events-none opacity-5 select-none">
    <div class="absolute top-1/2 left-1/4 w-80 h-80 rounded-full bg-gradient-preview-start blur-3xl"></div>
  </div>

  <div class="max-w-[1400px] mx-auto px-4 md:px-6 relative z-10">
    
    <!-- Section Header -->
    <div class="max-w-[700px] mb-16">
      <p class="caption-mono text-link mb-3 tracking-widest font-semibold">Credentials</p>
      <h2 class="display-lg text-3xl md:text-4xl text-ink leading-tight mb-4">
        Certifications & Certs.
      </h2>
      <p class="font-sans text-body text-base md:text-lg">
        Upcoming educational certifications and badges planned to validate full-stack web and cloud capabilities.
      </p>
    </div>

    <!-- Credentials Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {certifications.map((cert) => (
        <div class="bg-canvas border border-hairline hover:border-hairline-strong/50 rounded-lg p-6 flex flex-col justify-between shadow-level-2 hover:shadow-level-3 hover:-translate-y-1.5 transition-all duration-300 relative group overflow-hidden">
          
          <!-- Colored background radial blob on hover -->
          <div class={`absolute inset-0 bg-gradient-to-tr ${cert.color} opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none`}></div>
          
          <div class="relative z-10">
            <!-- Icon and tag -->
            <div class="flex items-center justify-between mb-4">
              <span class="p-2 bg-canvas-soft-2 border border-hairline/60 rounded-md group-hover:scale-105 transition-transform inline-block">
                <Fragment set:html={cert.icon} />
              </span>
              
              <span class="font-mono text-[9px] font-semibold text-mute bg-canvas-soft border border-hairline px-2 py-0.5 rounded-sm">
                {cert.status}
              </span>
            </div>

            <!-- Title -->
            <h3 class="font-sans font-semibold text-base text-ink mb-1 group-hover:text-primary transition-colors">
              {cert.title}
            </h3>

            <!-- Issuer -->
            <p class="font-sans text-mute text-xs mb-4">
              {cert.issuer}
            </p>
          </div>

          <!-- Decorative hairline signature -->
          <div class="pt-4 border-t border-hairline/50 mt-auto relative z-10 flex items-center justify-between">
            <span class="caption-mono text-[8px] text-mute tracking-wider font-semibold">Planned Verification</span>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 text-mute/50 group-hover:text-link group-hover:translate-x-0.5 transition-all">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>
