    color: "from-blue-500/20 via-teal-500/10 to-transparent",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-blue-500"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0V12a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 12V5.25" /></svg>`
  },
  {
    title: "JavaScript Programming",
    issuer: "MDN Academy / Udemy",
    status: "Planned",
    color: "from-yellow-500/20 via-amber-500/10 to-transparent",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-yellow-600"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" /></svg>`
  },
  {
    title: "Full Stack Development",
    issuer: "Udemy / Meta Cert",
    status: "Planned",
    color: "from-purple-500/20 via-pink-500/10 to-transparent",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-purple-500"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9s2.015-9 4.5-9yM12 3a9.004 9.004 0 0 1 8.716 6.747M12 3a9.004 9.004 0 0 0-8.716 6.747" /></svg>`
  },
  {
    title: "React Framework",
    issuer: "Meta / Frontend Masters",
    status: "Planned",
    color: "from-cyan-500/20 via-blue-500/10 to-transparent",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-cyan-500"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 21m0 0-.766-3.447m.766 3.447h2.625M17.188 15.904 18 21m0 0-.766-3.447m.766 3.447h-2.625M10.025 8h3.95M9.18 12h5.64M12 3v5m0 0-3 3m3-3 3 3" /></svg>`
  },
  {
    title: "Node.js System Design",
    issuer: "OpenJS Foundation",
