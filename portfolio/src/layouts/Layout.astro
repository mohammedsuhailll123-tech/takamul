---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Takamul Solutions Co. | Electrical & Mechanical Solutions Saudi Arabia", 
  description = "Authorized distributor of premium electrical and mechanical components. Powering Saudi Arabia's infrastructure in alignment with Saudi Vision 2030." 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect width=%22100%22 height=%22100%22 rx=%2220%22 fill=%22%23080b10%22/><text x=%2250%%22 y=%2265%%22 font-size=%2255%22 font-family=%22sans-serif%22 font-weight=%22bold%22 fill=%22%2306b6d4%22 text-anchor=%22middle%22>T</text></svg>" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 1200 630%22><rect width=%221200%22 height=%22630%22 fill=%22%23080b10%22/><text x=%22600%22 y=%22315%22 font-size=%2270%22 fill=%22%23ffffff%22 font-family=%22sans-serif%22 font-weight=%22bold%22 text-anchor=%22middle%22>Takamul Solutions Co.</text></svg>" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link 
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" 
      rel="stylesheet" 
    />

    {/* Non-blocking inline script to align user settings before paint */}
    <script is:inline>
      const theme = localStorage.getItem('theme') || 'dark';
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }

      const lang = localStorage.getItem('lang') || 'en';
      document.documentElement.setAttribute('lang', lang);
      document.documentElement.setAttribute('dir', lang === 'ar' ? 'rtl' : 'ltr');
    </script>
  </head>
  <body class="min-h-screen bg-canvas-soft text-ink antialiased">
    <slot />

    <!-- Floating WhatsApp Button -->
    <a 
      href="https://wa.me/966138576662" 
      target="_blank" 
      rel="noopener noreferrer" 
      class="fixed bottom-6 right-6 z-40 flex items-center justify-center bg-[#25D366] hover:bg-[#20ba5a] text-white w-14 h-14 rounded-full shadow-lg transition-all hover:scale-110 hover:-translate-y-1 active:scale-95 group focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#25D366]"
      aria-label="Chat with Takamul Solutions on WhatsApp"
      id="whatsapp-trigger"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16" class="filter drop-shadow-sm">
        <path d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.933 7.933 0 0 0 3.79.977h.004c4.403 0 8.062-3.557 8.066-7.93A7.98 7.98 0 0 0 13.6 2.326zM7.994 14.521a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592zm3.69-4.98c-.202-.12-1.19-.613-1.37-.674-.18-.063-.31-.097-.44.097-.13.197-.502.674-.618.81-.115.135-.23.149-.43.03a6.072 6.072 0 0 1-1.61-1.006a6.262 6.262 0 0 1-1.11-1.386c-.115-.197-.012-.303.088-.403.09-.09.2-.23.3-.346.09-.115.12-.197.18-.328.06-.13.03-.245-.015-.346-.045-.1-.44-1.1-.6-1.485-.156-.388-.314-.335-.44-.335-.115-.005-.25-.005-.385-.005-.137 0-.36.052-.55.258-.19.207-.73.714-.73 1.745s.75 2.023.85 2.16c.1.135 1.47 2.35 3.61 3.226.51.21 1.07.337 1.44.385.506.05 1.01.029 1.39-.029.42-.06 1.19-.502 1.36-.983.17-.48.17-.89.12-.983-.05-.09-.18-.12-.38-.24z"/>
      </svg>
      <!-- Tooltip -->
      <span 
        id="whatsapp-tooltip"
        class="absolute right-16 scale-0 group-hover:scale-100 opacity-0 group-hover:opacity-100 transition-all rounded-md bg-canvas text-ink border border-glass-border px-3 py-1.5 text-xs font-sans font-semibold shadow-md whitespace-nowrap z-40 select-none"
      >
        Chat on WhatsApp
      </span>
    </a>

    <script is:inline>
      // Script to adjust WhatsApp tooltip text based on active language
      const updateWhatsappText = () => {
        const lang = localStorage.getItem('lang') || 'en';
        const tooltip = document.getElementById('whatsapp-tooltip');
        if (tooltip) {
          tooltip.innerText = lang === 'ar' ? 'تواصل عبر الواتساب' : 'Chat on WhatsApp';
          
          // In RTL mode, align the tooltip to the left of the button
          if (lang === 'ar') {
            tooltip.style.right = 'auto';
            tooltip.style.left = '4rem';
          } else {
            tooltip.style.left = 'auto';
            tooltip.style.right = '4rem';
          }
        }
      };
      
      updateWhatsappText();
      // Listen to language swaps
      window.addEventListener('lang-change', (e) => {
        localStorage.setItem('lang', e.detail);
        updateWhatsappText();
      });
    </script>
  </body>
</html>
