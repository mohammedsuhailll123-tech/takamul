---
// Contact.astro
---

<section id="contact" class="py-24 bg-canvas-soft border-b border-hairline relative">
  <div class="max-w-[1400px] mx-auto px-4 md:px-6">
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      
      <!-- Left Column: Contact Text & Socials -->
      <div class="lg:col-span-5 flex flex-col justify-center">
        <p class="caption-mono text-link mb-3 tracking-widest font-semibold">Connect</p>
        <h2 class="display-lg text-3xl md:text-4xl text-ink leading-tight mb-4">
          Let's work together.
        </h2>
        <p class="font-sans text-body text-base md:text-lg mb-8 leading-relaxed">
          I'm currently accepting select freelance projects, consulting engagements, and full-time senior roles. If you have an idea, let's turn it into reality.
        </p>

        <!-- Direct Contact Details -->
        <div class="space-y-4 mb-8">
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-mute" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
            <a href="https://maps.google.com/?q=Ullal,%20Mangaluru,%20Karnataka" target="_blank" rel="noopener noreferrer" class="font-sans text-sm text-body hover:text-link transition-colors">
              Ullal, Mangaluru, Karnataka, India
            </a>
          </div>
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-mute" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.626a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
            <a href="mailto:mohdsuhailll123@gmail.com" class="font-mono text-sm text-body hover:text-link transition-colors">
              mohdsuhailll123@gmail.com
            </a>
          </div>
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-mute" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.824-1.143-5.12-3.439-6.264-6.264l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
            </svg>
            <a href="tel:+919036024148" class="font-mono text-sm text-body hover:text-link transition-colors">
              +91 9036024148
            </a>
          </div>
        </div>

        <!-- Social Buttons flex-row -->
        <div class="flex flex-wrap gap-3">
          <a 
            href="https://linkedin.com" 
            target="_blank" 
            rel="noopener noreferrer" 
            class="flex items-center justify-center border border-hairline hover:border-hairline-strong text-ink bg-canvas font-sans font-medium text-xs rounded-sm px-4 py-2 h-9 transition-colors shadow-sm"
          >
            LinkedIn
          </a>
          <a 
            href="https://github.com/mohammedsuhailll123-tech" 
            target="_blank" 
            rel="noopener noreferrer" 
            class="flex items-center justify-center border border-hairline hover:border-hairline-strong text-ink bg-canvas font-sans font-medium text-xs rounded-sm px-4 py-2 h-9 transition-colors shadow-sm"
          >
            GitHub
          </a>
          <a 
            href="https://twitter.com" 
            target="_blank" 
            rel="noopener noreferrer" 
            class="flex items-center justify-center border border-hairline hover:border-hairline-strong text-ink bg-canvas font-sans font-medium text-xs rounded-sm px-4 py-2 h-9 transition-colors shadow-sm"
          >
            Twitter / X
          </a>
        </div>
      </div>

      <!-- Right Column: Interactive Form -->
      <div class="lg:col-span-7">
        
        <div class="bg-canvas border border-hairline rounded-lg p-6 sm:p-10 shadow-level-4">
          <h3 class="display-md text-xl md:text-2xl text-ink font-semibold mb-6">
            Send a message.
          </h3>
          
          <form class="space-y-6" id="contact-form">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
              
              <div class="flex flex-col gap-2">
                <label for="name" class="caption-mono text-body text-[10px] tracking-wider font-semibold">Full Name</label>
                <input 
                  type="text" 
                  id="name" 
                  name="name" 
                  required
                  placeholder="John Doe"
                  class="bg-canvas text-ink border border-hairline hover:border-hairline-strong focus:border-link focus:outline-none font-sans text-sm rounded-sm px-4 h-10 w-full transition-colors shadow-sm"
                />
              </div>

              <div class="flex flex-col gap-2">
                <label for="email" class="caption-mono text-body text-[10px] tracking-wider font-semibold">Email Address</label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  required
                  placeholder="john@example.com"
                  class="bg-canvas text-ink border border-hairline hover:border-hairline-strong focus:border-link focus:outline-none font-sans text-sm rounded-sm px-4 h-10 w-full transition-colors shadow-sm"
                />
              </div>

              <div class="flex flex-col gap-2">
                <label for="phone" class="caption-mono text-body text-[10px] tracking-wider font-semibold">Phone Number</label>
                <input 
                  type="tel" 
                  id="phone" 
                  name="phone" 
                  required
                  placeholder="+91 9036024148"
                  class="bg-canvas text-ink border border-hairline hover:border-hairline-strong focus:border-link focus:outline-none font-sans text-sm rounded-sm px-4 h-10 w-full transition-colors shadow-sm"
                />
              </div>

            </div>

            <div class="flex flex-col gap-2">
              <label for="message" class="caption-mono text-body text-[10px] tracking-wider font-semibold">Message</label>
              <textarea 
                id="message" 
                name="message" 
                rows="5"
                required
                placeholder="Describe your project, timeline, or open role..."
                class="bg-canvas text-ink border border-hairline hover:border-hairline-strong focus:border-link focus:outline-none font-sans text-sm rounded-sm p-4 w-full transition-colors shadow-sm resize-none"
              ></textarea>
            </div>

            <!-- Form Status Notification (Hidden by default) -->
            <div id="form-status" class="hidden rounded-sm p-4 text-xs font-mono"></div>

            <button 
              type="submit" 
              class="w-full sm:w-auto inline-flex items-center justify-center bg-primary text-on-primary hover:bg-primary/95 text-sm font-semibold rounded-full px-8 py-3.5 transition-all shadow-level-3 active:scale-[0.98] cursor-pointer"
            >
              Send Message
            </button>
          </form>

        </div>

      </div>

    </div>

  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const statusDiv = document.getElementById('form-status');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!statusDiv) return;

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.innerText = 'Redirecting...';
    }

    // Extract form fields
    const formData = new FormData(form);
    const name = encodeURIComponent(String(formData.get('name') || ''));
    const email = encodeURIComponent(String(formData.get('email') || ''));
    const phone = encodeURIComponent(String(formData.get('phone') || ''));
    const message = encodeURIComponent(String(formData.get('message') || ''));

    // Construct WhatsApp message URL
    const whatsappUrl = `https://wa.me/919036024148?text=Hi%20Mohammed%20Suhail,%20I'm%20interested%20in%20your%20web%20development%20services.%0A%0AName:%20${name}%0AEmail:%20${email}%0APhone:%20${phone}%0AMessage:%20${message}`;

    // Show success/redirect status
    statusDiv.classList.remove('hidden', 'bg-error-soft', 'text-error-deep');
    statusDiv.classList.add('bg-link-bg-soft', 'text-link-deep');
    statusDiv.innerText = '✓ Redirecting to WhatsApp...';

    // Open WhatsApp URL in a new window/tab
    window.open(whatsappUrl, '_blank');

    // Reset button & form state after brief delay
    setTimeout(() => {
      form.reset();
      statusDiv.classList.add('hidden');
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.innerText = 'Send Message';
      }
    }, 2000);
  });
</script>
